{
  "expo": {
    "name": "BOOOMERANGS",
    "slug": "booomerangs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "booomerangs",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "ru.booomerangs.app",
      "supportsTablet": false
    },
    "android": {
      "package": "ru.booomerangs.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "minSdkVersion": 26,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://booomerangs.ru/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "2b29fee6-dde7-4663-9525-b1e38b57e34c"
      }
    },
    "owner": "misha1990"
  }
}
